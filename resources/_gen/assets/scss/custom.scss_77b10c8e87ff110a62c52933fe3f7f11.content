a{color:#3b82f6}a:hover{color:#60a5fa}.social-list a i,.social-list a svg,.social-list .fa-brands,.social-list .fab,.social-list .fa-github,.social-list .fa-linkedin{font-size:1.6rem!important;width:1.6rem!important;height:1.6rem!important;color:#3b82f6!important;display:inline-block!important;transition:color .2s ease}.social-list a:hover i,.social-list a:hover svg,.social-list a:hover .fa-brands,.social-list a:hover .fab,.social-list a:hover .fa-github,.social-list a:hover .fa-linkedin{color:#60a5fa!important}.content{max-width:900px;margin-left:auto;margin-right:auto;padding-left:1.5rem;padding-right:1.5rem}.content h1{font-size:4.2rem;margin-bottom:2.8rem}.content h2{font-size:2.75rem;margin-top:3.9rem;margin-bottom:1.3rem;padding-bottom:.45rem;border-bottom:1px solid rgba(59,130,246,.4)}.content h3{font-size:2.1rem;margin-top:2.4rem;margin-bottom:1rem}.content p{font-size:1.65rem;line-height:1.75;margin-bottom:1.65rem}.content ul{margin-top:.75rem;margin-bottom:1.75rem}.content li{font-size:1.65rem;line-height:1.65;margin-bottom:.55rem}.content strong{font-weight:700}.content .about-motto{margin-top:2.5rem;margin-bottom:0;font-size:2.2rem!important;font-style:italic!important;font-weight:700;line-height:1.4;letter-spacing:.01em;color:#f5f5f5;text-align:center}.content .about-motto em{font-style:italic!important}.content .heading-link,.content .anchor,.content .anchor-link,.content a[href^="#"]{display:none!important}